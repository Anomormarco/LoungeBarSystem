DATABASE_URL="postgresql://loungebar_user:loungebar_password@localhost:5433/loungebar"
CLIENT_ORIGIN="http://localhost:5173"
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="7d"
TZ="Asia/Ulaanbaatar"
RESERVATION_DURATION_MINUTES="120"
RESERVATION_EXPIRE_JOB_INTERVAL_MS="60000"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail@gmail.com"
# Gmail uses an App Password, not your normal Gmail password.
# Google Account -> Security -> 2-Step Verification -> App passwords.
SMTP_PASS="your-16-character-app-password"
EMAIL_FROM="your-gmail@gmail.com"

# SendGrid option: set this instead of SMTP_HOST/SMTP_USER/SMTP_PASS.
SENDGRID_API_KEY=""

# Resend option: preferred for Render/Vercel because it uses HTTPS instead of SMTP ports.
# To send OTP codes to every user, verify your own domain in Resend and set:
# EMAIL_FROM="noreply@your-verified-domain.mn"
RESEND_API_KEY=""

# Stripe Dashboard -> Developers -> API keys.
# Use your real test/live secret key in server/.env or deployment env, for example sk_test_...
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_PRICE_ID=""
STRIPE_CURRENCY="usd"
# Stripe test mode:
# 1. Set STRIPE_SECRET_KEY=sk_test_...
# 2. Create a Product + Price in Stripe test mode and set STRIPE_PRICE_ID=price_...
# 3. Add webhook endpoint directly to payment-service:
#    https://your-payment-service.onrender.com/payments/webhook/stripe
#    Events: checkout.session.completed, checkout.session.expired,
#    payment_intent.succeeded, payment_intent.payment_failed,
#    customer.subscription.updated, customer.subscription.deleted
# 4. Use test card 4242 4242 4242 4242 with any future date/CVC.
STRIPE_SUCCESS_URL="http://localhost:5173/subscription?success=true"
STRIPE_CANCEL_URL="http://localhost:5173/subscription"
STRIPE_PORTAL_RETURN_URL="http://localhost:5173/subscription"

QPAY_CALLBACK_URL="http://localhost:3000/payments/webhook/qpay"
