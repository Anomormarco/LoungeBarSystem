# Use Render's Internal Database URL inside Render services.
# Use Render's External Database URL when running Prisma migrations locally.
DATABASE_URL="postgresql://loungebar_user:YOUR_PASSWORD@YOUR_HOST:5432/loungebar?sslmode=require"
CLIENT_ORIGIN="http://localhost:5173"
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="7d"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# SendGrid option: set this instead of SMTP_HOST/SMTP_USER/SMTP_PASS.
SENDGRID_API_KEY=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SUCCESS_URL="http://localhost:5173/payment/success"
STRIPE_CANCEL_URL="http://localhost:5173/payment/cancel"

QPAY_CALLBACK_URL="http://localhost:3000/payments/webhook/qpay"
